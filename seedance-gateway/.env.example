# PPIO API 配置
SEEDANCE_API_KEYS=sk-your-ppio-api-key
SEEDANCE_BASE_URL=https://api.ppio.com

# Gateway 配置
GATEWAY_ACCESS_TOKEN=your-secret-token-here
ADMIN_ACCESS_TOKEN=your-admin-token-here
GATEWAY_PUBLIC_URL=http://127.0.0.1:8001

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 任务配置
TASK_POLL_INTERVAL=5
TASK_TIMEOUT=300
TASK_QUEUE_POP_TIMEOUT=5
TASK_EXECUTION_MODE=queue
MAX_CONCURRENT_TASKS=20
WORKER_RESTART_DELAY=3

# Seedance HTTP 连接池配置
SEEDANCE_SUBMIT_TIMEOUT=30
SEEDANCE_POLL_TIMEOUT=10
SEEDANCE_HTTP_MAX_CONNECTIONS=100
SEEDANCE_HTTP_MAX_KEEPALIVE_CONNECTIONS=20
SEEDANCE_HTTP_KEEPALIVE_EXPIRY=30
